# --- LLM ---
# Active provider: deepseek | openai
LLM_PROVIDER=deepseek

# Deepseek V3 (OpenAI-compatible)
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# --- Market data (Alpha Vantage NASDAQ feed) ---
ALPHAVANTAGE_API_KEY=
ALPHAVANTAGE_BASE_URL=https://www.alphavantage.co/query
ALPHAVANTAGE_RATE_LIMIT_PER_MIN=5
ALPHAVANTAGE_DEFAULT_EXCHANGE=NASDAQ
# Free tier: keep False. Uses TIME_SERIES_DAILY + outputsize=compact (latest ~100 bars).
# Set True only with a premium key to unlock adjusted closes and full history.
ALPHAVANTAGE_PREMIUM=false

# --- Storage ---
DB_URL=sqlite:///data/market.db
DATA_DIR=data
RAG_INDEX_DIR=data/faiss_index

# --- RAG ---
EMBED_MODEL=BAAI/bge-small-en-v1.5

# --- Misc ---
LOG_LEVEL=INFO
